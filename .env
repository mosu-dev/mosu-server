# 개발 환경 Spring 포트 설정
SPRING_PORT=20000

BASE_PATH=/api/v1

ENV_FILE=.env

# 개발 환경 데이터베이스 설정
DB_PORT=20001
DB_HOST=localhost
DB_DATABASE=sa
DB_USERNAME=sa
DB_PASSWORD=abcd
DB_URL=jdbc:mysql://${DB_HOST}:${DB_PORT}/${DB_DATABASE}

# 변경 예정
DB_MAX_ALLOWED_PACKET_SIZE=104857600

MAX_FILE_SIZE=10
MAX_REQUEST_SIZE=10